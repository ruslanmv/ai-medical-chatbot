# ============================================================
# MedOS — LLM provider configuration
# ============================================================
# All secrets are server-side only. The browser never sees them.
# Rename this file to `.env.local` (Next.js) or set the variables
# in your deployment platform (HF Space secrets, Vercel, etc.).

# ---- Primary: HuggingFace Inference Providers (free) ---------
# Get a token at https://huggingface.co/settings/tokens
# Grants access to Groq, Cerebras, SambaNova, Together, Fireworks,
# Nebius, Hyperbolic, Novita — all behind one OpenAI-compatible API.
HF_TOKEN=

# Default model used by the "free-best" preset. The `:groq` suffix
# pins routing to Groq; strip it to let HF auto-route.
HF_DEFAULT_MODEL=meta-llama/Llama-3.3-70B-Instruct

# ---- Optional: OllaBridge custom gateway ---------------------
# Point this at your own OllaBridge deployment to bring your own
# GPU / local models behind the same OpenAI-compatible contract.
OLLABRIDGE_URL=
OLLABRIDGE_API_KEY=
OLLABRIDGE_DEFAULT_MODEL=free-best

# ---- Optional: Local Ollama (server-side) --------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:7b

# ---- Default preset shown in the UI --------------------------
# One of: free-best | free-fastest | free-flexible | deep-reasoning | local | ollabridge
DEFAULT_PRESET=free-best

# ---- Runtime -------------------------------------------------
NODE_ENV=production
PORT=7860

# Note: Users can still BYO API keys (OpenAI / Gemini / Claude)
# entirely client-side through the Settings UI — no env required.
