# ============================================================
# MedOS Web (Vercel) — frontend-only configuration
# ============================================================
# The Vercel deployment is a pure frontend. All API calls go
# through /api/proxy/* to the HuggingFace Space backend.
# Zero secrets needed on Vercel (no LLM keys, no DB).

# Backend URL — the HuggingFace Space that handles all server logic.
NEXT_PUBLIC_BACKEND_URL=https://ruslanmv-medibot.hf.space

# That's it. All secrets (HF_TOKEN, DB, etc.) live on the HF Space.
