# OllaBridge-Cloud connection (primary LLM backend)
OLLABRIDGE_URL=https://ruslanmv-ollabridge.hf.space
OLLABRIDGE_API_KEY=sk-ollabridge-your-key-here

# HuggingFace Inference API (fallback if OllaBridge is unavailable)
HF_TOKEN=hf_your-token-here

# Default model alias (OllaBridge routes to best free provider)
DEFAULT_MODEL=free-best

# Application
NODE_ENV=production
PORT=7860
